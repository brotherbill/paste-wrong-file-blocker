{
  "name": "paste-shield",
  "displayName": "PasteShield (Internal)",
  "description": "Deterministic paste‑interception guard preventing full‑document replacement.",
  "version": "0.1.0",
  "publisher": "internal",
  "engines": {
    "vscode": "^1.50.0"
  },
  "activationEvents": [
    "onCommand:paste-shield.paste"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "paste-shield.paste",
        "title": "Paste with Shield"
      }
    ],
    "keybindings": [
      {
        "command": "paste-shield.paste",
        "key": "ctrl+v",
        "when": "editorTextFocus"
      }
    ]
  }
}
